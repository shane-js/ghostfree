{
  "name": "ghostfree",
  "displayName": "GhostFree - Dependency Vulnerability Scanner",
  "description": "Scans your repo's dependencies for known CVE vulnerabilities using OSV.dev, NVD, and CISA KEV — directly in your AI coding assistant.",
  "version": "0.2.0",
  "publisher": "shane-js",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shane-js/ghostfree.git"
  },
  "bugs": {
    "url": "https://github.com/shane-js/ghostfree/issues"
  },
  "homepage": "https://github.com/shane-js/ghostfree#readme",
  "engines": {
    "vscode": "^1.101.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "keywords": [
    "mcp",
    "security",
    "cve",
    "vulnerability",
    "osv",
    "sbom",
    "copilot"
  ],
  "icon": "logo.png",
  "main": "./out/extension.js",
  "activationEvents": ["onStartupFinished"],
  "contributes": {
    "mcpServerDefinitionProviders": [
      {
        "id": "ghostfree",
        "label": "GhostFree - Dependency Vulnerability Scanner"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/vscode": "^1.101.0",
    "typescript": "^5.8.3"
  }
}
